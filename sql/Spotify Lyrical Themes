CREATE TEMP FUNCTION canon(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(LOWER(IFNULL(x,'')), r'\([^)]*\)|\[[^\]]*\]', ' '),
        r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '
      ),
      r'[^a-z0-9]+', ' '
    ),
    r'\s+', ' '
  ))
);

WITH sp AS (
  SELECT song, artist, MIN(rank) AS sp_peak_rank, COUNT(*) AS sp_total_weeks, canon(song) AS k 
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.spotify_global_2017-2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY song, artist
), 
s AS (
  SELECT song, album_name, `Color Words` AS colour_words,
    `Nature Words` AS nature_words, `Total Words` AS total_words,
    `Unique Words` AS unique_words, `Dominant Pronoun` AS dominant_pronoun, `Body Parts` AS body_parts,
    canon(song) AS k 
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.taylorswift_lyrics_and_sentiment`
),
deduped AS (
  SELECT
    sp.song,
    sp.sp_peak_rank,
    sp.sp_total_weeks,
    s.album_name, 
    s.colour_words, 
    s.nature_words, 
    s.total_words, 
    s.unique_words, 
    s.dominant_pronoun,
    s.body_parts
  FROM sp
  LEFT JOIN s ON sp.k = s.k
  QUALIFY ROW_NUMBER() OVER (
    PARTITION BY sp.song
    ORDER BY (s.album_name IS NOT NULL) DESC
  ) = 1
)
SELECT 
  song, 
  album_name,
  sp_peak_rank,
  sp_total_weeks,
  colour_words, 
  nature_words, 
  total_words,
  body_parts
FROM deduped
WHERE colour_words > 10 OR nature_words > 10 OR body_parts > 10
ORDER BY sp_peak_rank
