CREATE TEMP FUNCTION canon_keep(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        LOWER(IFNULL(x,'')),
        r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '
      ),
      r'[\(\)\[\]]', ' '
    ),
    r'[^a-z0-9]+', ' '
  ))
);

CREATE TEMP FUNCTION canon_drop(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(LOWER(IFNULL(x,'')), r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '),
        r'\([^)]*\)|\[[^\]]*\]', ' '
      ),
      r'[^a-z0-9]+', ' '
    ),
    r'\s+', ' '
  ))
);

WITH sp AS (
  SELECT
    song,
    artist,
    MIN(rank) AS sp_peak_rank,
    COUNT(*) AS sp_total_weeks,
    canon_keep(song) AS k_keep,
    canon_drop(song) AS k_drop,
    LOWER(TRIM(song)) AS song_lc
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.spotify_global_2017-2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY song, artist
),
s AS (
  SELECT
    song,
    album_name,
    `Color Words` AS colour_words,
    `Nature Words` AS nature_words,
    `Total Words` AS total_words,
    `Unique Words` AS unique_words,
    `Dominant Pronoun` AS dominant_pronoun,
    `Body Parts` AS body_parts,
    bridge,
    `Lexical Diversity` AS `lexical-diversity`,
    canon_keep(song) AS k_keep,
    canon_drop(song) AS k_drop,
    LOWER(TRIM(song)) AS song_lc
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.taylorswift_lyrics_and_sentiment`
),
joined AS (
  SELECT
    sp.song,
    sp.artist,
    sp.sp_peak_rank,
    sp.sp_total_weeks,
    s.song AS matched_song,
    s.album_name,
    s.colour_words,
    s.nature_words,
    s.total_words,
    s.unique_words,
    s.dominant_pronoun,
    s.`lexical-diversity`,
    s.body_parts,
    s.bridge,
    ROW_NUMBER() OVER (
      PARTITION BY sp.song
      ORDER BY
        (sp.k_keep = s.k_keep) DESC,
        (sp.k_drop = s.k_drop) DESC,
        (s.song_lc = sp.song_lc) DESC,
        ABS(LENGTH(s.song_lc) - LENGTH(sp.song_lc)) ASC
    ) AS rn
  FROM sp
  LEFT JOIN s
    ON (sp.k_keep = s.k_keep) OR (sp.k_drop = s.k_drop)
)

SELECT
  song,
  artist,
  album_name,
  sp_peak_rank,
  sp_total_weeks,
  unique_words,
  `lexical-diversity`,
  bridge,
  AVG(unique_words) OVER () AS avg_unique_words,
  AVG(`lexical-diversity`) OVER () AS avg_lexical_diversity
FROM joined
WHERE rn = 1
  AND matched_song IS NOT NULL
ORDER BY sp_peak_rank, sp_total_weeks DESC, song;
