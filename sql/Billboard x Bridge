CREATE TEMP FUNCTION canon_keep(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        LOWER(IFNULL(x,'')),
        r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '
      ),
      r'[\(\)\[\]]', ' '
    ),
    r'[^a-z0-9]+', ' '
  ))
);

CREATE TEMP FUNCTION canon_drop(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(LOWER(IFNULL(x,'')), r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '),
        r'\([^)]*\)|\[[^\]]*\]', ' '
      ),
      r'[^a-z0-9]+', ' '
    ),
    r'\s+', ' '
  ))
);

WITH b AS (
  SELECT
    song,
    artist,
    MIN(peak_rank) AS peak_rank,
    COUNT(*) AS total_weeks,
    canon_keep(song) AS k_keep,
    canon_drop(song) AS k_drop,
    LOWER(TRIM(song)) AS song_lc
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.billboard_hot100_1958_2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY song, artist
),
s AS (
  SELECT
    song,
    album_name,
    colour_words,
    nature_words,
    total_words,
    unique_words,
    dominant_pronoun,
    body_parts,
    bridge,
    `lexical-diversity`,
    canon_keep(song) AS k_keep,
    canon_drop(song) AS k_drop,
    LOWER(TRIM(song)) AS song_lc
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.taylorswift_lyrics_and_sentiment_analysis`
),
joined AS (
  SELECT
    b.song,
    b.peak_rank,
    b.total_weeks,
    s.song AS matched_song,           -- <— add this so we can filter reliably
    s.album_name,
    s.colour_words,
    s.nature_words,
    s.total_words,
    s.unique_words,
    s.dominant_pronoun,
    s.`lexical-diversity`,
    s.body_parts,
    s.bridge,
    ROW_NUMBER() OVER (
      PARTITION BY b.song
      ORDER BY
        (b.k_keep = s.k_keep) DESC,
        (b.k_drop = s.k_drop) DESC,
        (s.song_lc = b.song_lc) DESC,
        ABS(LENGTH(s.song_lc) - LENGTH(b.song_lc)) ASC
    ) AS rn
  FROM b
  LEFT JOIN s
    ON (b.k_keep = s.k_keep) OR (b.k_drop = s.k_drop)
)
SELECT
  song,
  album_name,
  peak_rank,
  unique_words,
  `lexical-diversity`,
  bridge,
  AVG(unique_words) OVER () AS avg_unique_words,
  AVG(`lexical-diversity`) OVER () AS avg_lexical_diversity
FROM joined
WHERE rn = 1
  AND matched_song IS NOT NULL     -- <— deletes Billboard rows with no sentiment match
ORDER BY peak_rank;
