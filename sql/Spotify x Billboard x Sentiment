CREATE TEMP FUNCTION canon(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(LOWER(IFNULL(x,'')), r'\([^)]*\)|\[[^\]]*\]', ' '),
        r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '
      ),
      r'[^a-z0-9]+', ' '
    ),
    r'\s+', ' '
  ))
);

WITH sp AS (
  SELECT
    song,
    artist,
    MIN(rank) AS sp_peak_rank,
    COUNT(*) AS sp_total_weeks,
    canon(song) AS k
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.spotify_global_2017-2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY song, artist, k
),
bb AS (
  SELECT
    song,
    artist,
    MIN(peak_rank) AS bb_peak_rank,
    COUNT(*) AS bb_total_weeks,   -- weeks on Hot 100 (rows)
    canon(song) AS k
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.billboard_hot100_1958_2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY song, artist, k
),
s AS (
  SELECT
    song,
    album_name,
    Sentiment,
    `Sentiment Score` AS sentiment_score,
    canon(song) AS k
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.taylorswift_lyrics_and_sentiment`
),
joined AS (
  SELECT
    COALESCE(sp.song, bb.song) AS song,
    sp.sp_peak_rank,
    sp.sp_total_weeks,
    bb.bb_peak_rank,
    bb.bb_total_weeks,
    s.album_name,
    s.Sentiment,
    s.sentiment_score
  FROM sp
  FULL OUTER JOIN bb
    ON sp.k = bb.k
  LEFT JOIN s
    ON COALESCE(sp.k, bb.k) = s.k
  QUALIFY ROW_NUMBER() OVER (
    PARTITION BY COALESCE(sp.song, bb.song)
    ORDER BY (s.album_name IS NOT NULL) DESC
  ) = 1
)

SELECT
  Sentiment,
  sentiment_score,
  COUNT(*) AS song_count,

  ROUND(AVG(sp_peak_rank), 2) AS avg_sp_peak_rank,
  ROUND(AVG(sp_total_weeks), 2) AS avg_sp_weeks,
  COUNTIF(sp_peak_rank = 1) AS spotify_n1_songs,

  ROUND(AVG(bb_peak_rank), 2) AS avg_bb_peak_rank,
  ROUND(AVG(bb_total_weeks), 2) AS avg_bb_weeks,
  COUNTIF(bb_peak_rank = 1) AS billboard_n1_songs
FROM joined
WHERE Sentiment IS NOT NULL
  AND sentiment_score IS NOT NULL
GROUP BY Sentiment, sentiment_score
ORDER BY avg_bb_peak_rank ASC, avg_sp_peak_rank ASC, sentiment_score;
