CREATE TEMP FUNCTION canon(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(LOWER(IFNULL(x,'')), r'\([^)]*\)|\[[^\]]*\]', ' '),
        r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '
      ),
      r'[^a-z0-9]+', ' '
    ),
    r'\s+', ' '
  ))
);

WITH
billboard AS (
  SELECT
    song,
    canon(song) AS k,
    MIN(peak_rank) AS peak_rank,
    COUNT(*) AS total_weeks
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.billboard_hot100_1958_2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY song, k
),
spotify AS (
  SELECT
    canon(song) AS k,
    MIN(rank) AS rank, -- best (highest) Spotify position across all weeks
    MAX(CAST(Explicit AS INT64)) AS explicit_flag
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.spotify_global_2017-2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY k
)
SELECT
  b.song,
  s.rank AS spotify_rank,
  b.peak_rank AS billboard_peak_rank,
  b.total_weeks,
  IF(s.explicit_flag = 1, 'Yes', 'No') AS is_explicit
FROM billboard b
LEFT JOIN spotify s
  ON b.k = s.k
-- keep this WHERE only if you truly want songs that exist in Spotify
WHERE s.rank IS NOT NULL
ORDER BY b.peak_rank, s.rank, b.song;
