CREATE TEMP FUNCTION canon_match(x STRING) AS (
  TRIM(REGEXP_REPLACE(
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(
          REGEXP_REPLACE(
            REGEXP_REPLACE(
              LOWER(IFNULL(x,'')),
              r'\b(feat\.?|ft\.?|featuring)\b.*$', ' '
            ),
            r'[\(\)\[\]]', ' '
          ),
          r'\bminutes\b', ' minute '
        ),
        r"(taylor'?s\s+version|\btv\b)", ' '
      ),
      r'from\s+the\s+vault', ' '
    ),
    r'[^a-z0-9]+', ' '
  ))
);

WITH b AS (
  SELECT
    song, artist,
    MIN(peak_rank) AS bb_peak_rank,
    canon_match(song) AS k
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.billboard_hot100_1958_2025`
  WHERE artist LIKE '%Taylor Swift%'
  GROUP BY song, artist
),
sp AS (
  SELECT
    canon_match(song) AS k,
    MIN(rank) AS sp_peak_rank,
    ARRAY_AGG(Artist_Genres ORDER BY rank ASC, date ASC LIMIT 1)[OFFSET(0)] AS artist_genres
  FROM `ts-sentiment-and-charts.ts_sentiment_and_charts.spotify_global_2017-2025`
  GROUP BY k
),
joined AS (
  SELECT
    b.song,
    sp.sp_peak_rank,
    b.bb_peak_rank,
    sp.artist_genres
  FROM b
  LEFT JOIN sp USING (k)
  WHERE sp.sp_peak_rank IS NOT NULL
    AND sp.artist_genres IS NOT NULL
),
exploded AS (
  SELECT
    song,
    bb_peak_rank,
    sp_peak_rank,
    genre
  FROM joined,
  UNNEST(ARRAY(
    SELECT g FROM UNNEST([
      IF(artist_genres LIKE '%synth-pop%', 'Synth-pop', NULL),
      IF(artist_genres LIKE '%country%',   'Country',   NULL),
      IF(artist_genres LIKE '%folk%',      'Folk',      NULL),
      IF(artist_genres LIKE '%rock%',      'Pop Rock',  NULL),
      IF(artist_genres LIKE '%pop%',       'Pop',       NULL)
    ]) AS g
    WHERE g IS NOT NULL
  )) AS genre
)
SELECT
  genre,
  COUNT(DISTINCT song) AS song_count,
  ROUND(AVG(bb_peak_rank), 1) AS avg_bb_peak_rank,
  ROUND(AVG(sp_peak_rank), 1) AS avg_sp_peak_rank
FROM exploded
GROUP BY genre
ORDER BY song_count DESC;
